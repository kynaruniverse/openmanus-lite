# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored — never commit real secrets.

# ---------- Pick a provider ----------
# Default: gemini.  Other options: openai, anthropic, ollama, openrouter
# OMX_PROVIDER=gemini

# ---------- Provider keys (set the one(s) you'll use) ----------
# Get a free Gemini key at https://aistudio.google.com/
GEMINI_API_KEY=

# Get an OpenAI key at https://platform.openai.com/
# OPENAI_API_KEY=

# Get an Anthropic key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# Get an OpenRouter key at https://openrouter.ai/keys (one key, 100+ models)
# OPENROUTER_API_KEY=

# Ollama needs no key — just install https://ollama.com and run `ollama serve`.

# ---------- Optional model override ----------
# Each provider has a sensible default. Override here if you like.
# OMX_MODEL=models/gemini-2.5-flash-lite
# OMX_MODEL=gpt-4o-mini
# OMX_MODEL=claude-3-5-haiku-latest
# OMX_MODEL=llama3.2
# OMX_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ---------- Other tunables ----------
# OMX_LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
# OMX_LOG_FILE=omx.log
# OMX_BUDGET=20             # hard cap on LLM calls per task; 0 = unlimited
# OMX_CACHE_TTL=86400       # cache entry lifetime in seconds; 0 = no expiry
# OMX_MAX_STEPS=10
# OMX_BASE_URL=             # only for ollama / openrouter / OpenAI-compat APIs
