# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored — never commit real secrets.

# Required: Google Gemini API key (https://aistudio.google.com/)
GEMINI_API_KEY=

# Optional: override the default model
# OMX_MODEL=models/gemini-2.0-flash

# Optional: log level (DEBUG, INFO, WARNING, ERROR). Default: INFO
# OMX_LOG_LEVEL=INFO

# Optional: file to write structured logs to (default: omx.log)
# OMX_LOG_FILE=omx.log
