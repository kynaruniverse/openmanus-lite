modules = ["python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "OpenManus CLI"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Web UI"

[[workflows.workflow]]
name = "OpenManus CLI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py --help"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Web UI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py --web --host 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
